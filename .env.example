# =============================================================================
# VertexED.ai — Environment Variables
# Copy this file to `.env.local` for local development.
# Set the same values in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth + waitlist)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used by /api/waitlist + JWT verification (never expose service role in client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# OpenAI (required for AI features: chatbot, notes, quiz, review, paper maker)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Legacy alias used by several API handlers (can match OPENAI_API_KEY)
ChatbotKey=sk-...

# Optional overrides
CHATBOT_MODEL=ft:gpt-4.1-mini-2025-04-14:verteded:apex-chatbot:CSgJ1mRt
CHATBOT_FALLBACK_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4.1

# -----------------------------------------------------------------------------
# Google Gemini (Study Planner — server only via /api/planner)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# VITE_CHATBOT_API_URL=https://www.vertexed.app/api/ask
# WORKFLOW_ID=wf_...
# ENABLE_TEST_AGENTS=true

# Optional: salt for waitlist IP rate-limit hashing (required in production)
WAITLIST_RATE_LIMIT_SALT=random-string

# Server-only: anon key for JWT verification on AI routes (same as VITE_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=your-anon-key

# Comma-separated admin emails for /admin/waitlist (server-only)
ADMIN_EMAILS=you@example.com

# Server-only: invite code for fast-track signup via /api/signup-invite (never expose to client)
SIGNUP_INVITE_CODE=your-secret-invite-code-here

# Waitlist approval emails (Resend — optional but recommended in production)
RESEND_API_KEY=re_...
RESEND_FROM=VertexED <onboarding@vertexed.app>

# Public site URL for invite links and approval emails
APP_URL=https://www.vertexed.app
# SITE_URL=https://www.vertexed.app

# Client-side fallback for admin nav gating only (server enforces ADMIN_EMAILS)
# VITE_ADMIN_EMAILS=you@example.com

# -----------------------------------------------------------------------------
# Database migrations (run in Supabase SQL editor for cloud save + waitlist invites)
# supabase/migrations/20260709_user_study_artifacts.sql
# supabase/migrations/20260711_waitlist_invite_token.sql
# supabase/migrations/20260711_artifact_kinds_planner_notebook.sql
# -----------------------------------------------------------------------------
